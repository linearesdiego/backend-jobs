generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Rol {
  ADMIN
  CONTRATADOR
  PROVEEDOR
}

enum PostulacionEstado {
  ACTIVA
  PAUSADA
  FINALIZADA
}

model Usuario {
  id            String   @id @default(uuid())
  email         String   @unique
  clave         String
  rol           Rol
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // relaciones
  perfilContratador PerfilContratador?
  perfilProveedor   PerfilProveedor?
  mensajes          Mensaje[]
}

model PerfilContratador {
  id             String  @id @default(uuid())
  usuario        Usuario @relation(fields: [usuarioId], references: [id])
  usuarioId      String  @unique
  nombreCompleto String?
  nombreUsuario  String?
  cuit           String?
  direccion      String?
  ciudad         String?
  codigoPostal   String?
  telefono       String?
}

model PerfilProveedor {
  id             String               @id @default(uuid())
  usuario        Usuario              @relation(fields: [usuarioId], references: [id])
  usuarioId      String               @unique
  nombreCompleto String
  nombreUsuario  String?
  rubro          String?
  experiencia    Int? // años
  descripcion    String?
  telefono       String?
  direccion      String?
  ciudad         String?
  codigoPostal   String?
  perfilCompleto Boolean              @default(false)
  postulaciones  Postulacion[]
  documentos     DocumentoProveedor[]
}

model Postulacion {
  id             String            @id @default(uuid())
  proveedor      PerfilProveedor   @relation(fields: [proveedorId], references: [id])
  proveedorId    String
  titulo         String
  descripcion    String
  categoria      String?
  precioEstimado Float?
  estado         PostulacionEstado @default(ACTIVA)
  creadoEn       DateTime          @default(now())

  videos PostulacionVideo[]
  chats  Chat[]
}

model PostulacionVideo {
  id               String      @id @default(uuid())
  postulacion      Postulacion @relation(fields: [postulacionId], references: [id])
  postulacionId    String
  url              String // URL pública al objeto en storage
  clave            String? // key en S3/MinIO
  urlMiniatura     String? // si generás thumbnail
  duracionSegundos Int? // duración en segundos
  tipoMime         String?
  creadoEn         DateTime    @default(now())
}

model Chat {
  id            String      @id @default(uuid())
  postulacion   Postulacion @relation(fields: [postulacionId], references: [id])
  postulacionId String
  creadoEn      DateTime    @default(now())

  mensajes Mensaje[]
}

model Mensaje {
  id          String   @id @default(uuid())
  chat        Chat     @relation(fields: [chatId], references: [id])
  chatId      String
  remitente   Usuario  @relation(fields: [remitenteId], references: [id])
  remitenteId String
  texto       String?
  urlAdjunto  String? // opcional: url al archivo enviado
  tipoAdjunto String? // mime-type si corresponde
  creadoEn    DateTime @default(now())
}

model DocumentoProveedor {
  id          String          @id @default(uuid())
  proveedor   PerfilProveedor @relation(fields: [proveedorId], references: [id])
  proveedorId String
  url         String
  tipo        String
  creadoEn    DateTime        @default(now())
}
