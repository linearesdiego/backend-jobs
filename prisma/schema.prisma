generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  CONTRACTOR
  PROVIDER
}

enum ProviderStatus {
  ACTIVE
  PAUSED
  FINISHED
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  contractorProfile ContractorProfile?
  providerProfile   ProviderProfile?
  messages          Message[]
}

model ContractorProfile {
  id       String  @id @default(uuid())
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId   String  @unique
  fullName String?
  username String?
  cuit     String?
  address  String?
  city     String?
  state    String?
  zipCode  String?
  phone    String?

  // Relations
  ratings Rating[]
}

model ProviderProfile {
  id              String  @id @default(uuid())
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId          String  @unique
  fullName        String
  username        String?
  trade           String?
  experience      Int? // years
  phone           String?
  address         String?
  city            String?
  state           String?
  zipCode         String?
  profileComplete Boolean @default(false)

  // Application fields
  title          String?
  description    String?
  category       String?
  estimatedPrice Float?
  status         ProviderStatus @default(ACTIVE)

  // Video fields
  videoUrl             String? // Public URL to storage object
  videoKey             String? // key in S3/MinIO
  videoThumbnailUrl    String? // if you generate thumbnail
  videoDurationSeconds Int? // duration in seconds
  videoMimeType        String?

  applicationCreatedAt DateTime?

  // Rating fields
  averageRating Float @default(0) // Promedio de calificaciones
  totalRatings  Int   @default(0) // Número total de calificaciones

  // Relations
  chats     Chat[]
  documents ProviderDocument[]
  ratings   Rating[]
}

model Chat {
  id         String          @id @default(uuid())
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String
  createdAt  DateTime        @default(now())

  messages Message[]
}

model Message {
  id             String   @id @default(uuid())
  chat           Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId         String
  sender         User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderId       String
  text           String?
  attachmentUrl  String? // optional: url to sent file
  attachmentType String? // mime-type if applicable
  createdAt      DateTime @default(now())
}

model ProviderDocument {
  id         String          @id @default(uuid())
  provider   ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId String
  url        String
  type       String
  createdAt  DateTime        @default(now())
}

model Rating {
  id                  String            @id @default(uuid())
  provider            ProviderProfile   @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId          String
  contractor          ContractorProfile @relation(fields: [contractorProfileId], references: [id], onDelete: Cascade)
  contractorProfileId String
  rating              Int // Puntuación de 1 a 5
  comment             String? // Comentario opcional
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([providerId, contractorProfileId]) // Un contratador solo puede calificar una vez a cada proveedor
  @@index([providerId])
}
