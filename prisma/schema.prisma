generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model ad {
  id           String      @id @default(uuid())
  title        String
  mediaUrl     String
  mediaKey     String
  mediaType    String
  placement    AdPlacement
  isActive     Boolean     @default(true)
  linkUrl      String?
  uploadedById String
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  uploadedBy   user        @relation(fields: [uploadedById], references: [id], onDelete: Cascade, map: "Ad_uploadedById_fkey")

  @@index([placement, isActive], map: "Ad_placement_isActive_idx")
  @@index([uploadedById], map: "Ad_uploadedById_fkey")
}

model AdminLog {
  id              String   @id @default(uuid())
  action          String
  performedById   String
  targetUserId    String?
  targetAdId      String?
  details         String?
  createdAt       DateTime @default(now())
  targetUserEmail String?  @db.VarChar(255)
  performedBy     user     @relation(fields: [performedById], references: [id], onDelete: Cascade, map: "AdminLog_performedById_fkey")

  @@index([createdAt], map: "AdminLog_createdAt_idx")
  @@index([performedById], map: "AdminLog_performedById_idx")
  @@map("adminlog")
}

model chat {
  id         String          @id @default(uuid())
  createdAt  DateTime        @default(now())
  providerId String
  provider   providerProfile @relation(fields: [providerId], references: [id], onDelete: Cascade, map: "Chat_providerId_fkey")
  messages   message[]

  @@index([providerId], map: "Chat_providerId_fkey")
}

model contractorProfile {
  id       String   @id @default(uuid())
  userId   String   @unique(map: "ContractorProfile_userId_key")
  fullName String?
  username String?
  cuit     String?
  address  String?
  city     String?
  state    String?
  zipCode  String?
  phone    String?
  profileImageUrl   String?
  profileImageMedia String?
  user     user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ContractorProfile_userId_fkey")
  rating   rating[]
}

model message {
  id             String   @id @default(uuid())
  chatId         String
  senderId       String
  text           String?
  attachmentUrl  String?
  attachmentType String?
  createdAt      DateTime @default(now())
  chat           chat     @relation(fields: [chatId], references: [id], onDelete: Cascade, map: "Message_chatId_fkey")
  sender         user     @relation(fields: [senderId], references: [id], onDelete: Cascade, map: "Message_senderId_fkey")

  @@index([chatId], map: "Message_chatId_fkey")
  @@index([senderId], map: "Message_senderId_fkey")
}

model notification {
  id        String   @id @default(uuid())
  userId    String
  type      String
  title     String
  body      String
  chatId    String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, map: "Notification_userId_fkey")

  @@index([userId, createdAt], map: "Notification_userId_createdAt_idx")
  @@index([userId, isRead], map: "Notification_userId_isRead_idx")
}

model providerDocument {
  id              String          @id @default(uuid())
  providerId      String
  url             String
  type            String
  createdAt       DateTime        @default(now())
  providerProfile providerProfile @relation(fields: [providerId], references: [id], onDelete: Cascade, map: "ProviderDocument_providerId_fkey")

  @@index([providerId], map: "ProviderDocument_providerId_fkey")
}

model providerProfile {
  id                   String             @id @default(uuid())
  userId               String             @unique(map: "ProviderProfile_userId_key")
  fullName             String
  username             String?
  trade                String?
  experience           Int?
  phone                String?
  address              String?
  city                 String?
  state                String?
  zipCode              String?
  profileComplete      Boolean            @default(false)
  title                String?
  description          String?
  category             String?
  estimatedPrice       Float?
  status               ProviderStatus     @default(ACTIVE)
  videoUrl             String?
  videoKey             String?
  videoThumbnailUrl    String?
  videoDurationSeconds Int?
  videoMimeType        String?
  applicationCreatedAt DateTime?
  averageRating        Float              @default(0)
  totalRatings         Int                @default(0)
  profileImageUrl      String?
  profileImageMedia    String?
  chat                 chat[]
  providerDocument     providerDocument[]
  user                 user               @relation(fields: [userId], references: [id], onDelete: Cascade, map: "ProviderProfile_userId_fkey")
  rating               rating[]
}

model rating {
  id                  String            @id @default(uuid())
  providerId          String
  contractorProfileId String
  rating              Int
  comment             String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  contractor          contractorProfile @relation(fields: [contractorProfileId], references: [id], onDelete: Cascade, map: "Rating_contractorProfileId_fkey")
  providerProfile     providerProfile   @relation(fields: [providerId], references: [id], onDelete: Cascade, map: "Rating_providerId_fkey")

  @@unique([providerId, contractorProfileId], map: "Rating_providerId_contractorProfileId_key")
  @@index([contractorProfileId], map: "Rating_contractorProfileId_fkey")
  @@index([providerId], map: "Rating_providerId_idx")
}

model user {
  id                String             @id @default(uuid())
  email             String             @unique(map: "User_email_key")
  password          String
  role              Role
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  isVerified        Boolean            @default(false)
  isBanned          Boolean            @default(false)
  ad                ad[]
  adminLogs         AdminLog[]
  contractorProfile contractorProfile?
  message           message[]
  notification      notification[]
  providerProfile   providerProfile?
}

enum Role {
  ADMIN
  MOD
  CONTRACTOR
  PROVIDER
}

enum AdPlacement {
  HEADER
  SIDEBAR
  FEED
}

enum ProviderStatus {
  ACTIVE
  PAUSED
  FINISHED
}
