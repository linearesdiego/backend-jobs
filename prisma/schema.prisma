generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Role {
  ADMIN
  CONTRATADOR
  PROVEEDOR
}

enum PostulacionEstado {
  ACTIVA
  PAUSADA
  FINALIZADA
}

enum ContratoEstado {
  INICIADO
  EN_PROGRESO
  CANCELADO
  FINALIZADO
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  contractorProfile ContractorProfile?
  providerProfile   ProviderProfile?
  mensajes          Mensaje[]
}

model ContractorProfile {
  id          String  @id @default(uuid())
  user        User    @relation(fields: [userId], references: [id])
  userId      String  @unique
  companyName String?
  cuit        String?
  address     String?
  phone       String?

  contratos Contrato[]
}

model ProviderProfile {
  id             String  @id @default(uuid())
  user           User    @relation(fields: [userId], references: [id])
  userId         String  @unique
  name           String
  rubro          String?
  experiencia    Int? // años
  descripcion    String?
  phone          String?
  address        String?
  perfilCompleto Boolean @default(false)

  postulaciones Postulacion[]
  documents     ProviderDocument[]
  contratoes    Contrato[]
}

model Postulacion {
  id             String            @id @default(uuid())
  provider       ProviderProfile   @relation(fields: [providerId], references: [id])
  providerId     String
  titulo         String
  descripcion    String
  categoria      String?
  precioEstimado Float?
  estado         PostulacionEstado @default(ACTIVA)
  createdAt      DateTime          @default(now())

  videos    PostulacionVideo[]
  contratos Contrato[]
}

model PostulacionVideo {
  id            String      @id @default(uuid())
  postulacion   Postulacion @relation(fields: [postulacionId], references: [id])
  postulacionId String
  url           String // URL pública al objeto en storage
  key           String? // key en S3/MinIO
  thumbnailUrl  String? // si generás thumbnail
  durationSec   Int? // duración en segundos
  mimeType      String?
  createdAt     DateTime    @default(now())
}

model Contrato {
  id            String            @id @default(uuid())
  contractor    ContractorProfile @relation(fields: [contractorId], references: [id])
  contractorId  String
  provider      ProviderProfile   @relation(fields: [providerId], references: [id])
  providerId    String
  postulacion   Postulacion?      @relation(fields: [postulacionId], references: [id])
  postulacionId String?
  estado        ContratoEstado    @default(INICIADO)
  createdAt     DateTime          @default(now())

  chat Chat?
}

model Chat {
  id         String   @id @default(uuid())
  contrato   Contrato @relation(fields: [contratoId], references: [id])
  contratoId String   @unique
  createdAt  DateTime @default(now())

  mensajes Mensaje[]
}

model Mensaje {
  id             String   @id @default(uuid())
  chat           Chat     @relation(fields: [chatId], references: [id])
  chatId         String
  sender         User     @relation(fields: [senderId], references: [id])
  senderId       String
  texto          String?
  attachmentUrl  String? // opcional: url al archivo enviado
  attachmentType String? // mime-type si corresponde
  createdAt      DateTime @default(now())
}

model ProviderDocument {
  id         String          @id @default(uuid())
  provider   ProviderProfile @relation(fields: [providerId], references: [id])
  providerId String
  url        String
  tipo       String
  createdAt  DateTime        @default(now())
}
