generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

enum Rol {
  ADMIN
  CONTRATADOR
  PROVEEDOR
}

enum PostulacionEstado {
  ACTIVA
  PAUSADA
  FINALIZADA
}

model Usuario {
  id            String   @id @default(uuid())
  email         String   @unique
  clave         String
  rol           Rol
  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  // relaciones
  perfilContratador PerfilContratador?
  perfilProveedor   PerfilProveedor?
  mensajes          Mensaje[]
}

model PerfilContratador {
  id             String  @id @default(uuid())
  usuario        Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId      String  @unique
  nombreCompleto String?
  nombreUsuario  String?
  cuit           String?
  direccion      String?
  ciudad         String?
  codigoPostal   String?
  telefono       String?
}

model PerfilProveedor {
  id             String               @id @default(uuid())
  usuario        Usuario              @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  usuarioId      String               @unique
  nombreCompleto String
  nombreUsuario  String?
  rubro          String?
  experiencia    Int? // años
  descripcion    String?
  telefono       String?
  direccion      String?
  ciudad         String?
  codigoPostal   String?
  perfilCompleto Boolean              @default(false)
  postulaciones  Postulacion[]
  documentos     DocumentoProveedor[]
}

model Postulacion {
  id                    String            @id @default(uuid())
  proveedor             PerfilProveedor   @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  proveedorId           String
  titulo                String
  descripcion           String
  categoria             String?
  precioEstimado        Float?
  estado                PostulacionEstado @default(ACTIVA)
  // campos de video
  videoUrl              String? // URL pública al objeto en storage
  videoClave            String? // key en S3/MinIO
  videoUrlMiniatura     String? // si generás thumbnail
  videoDuracionSegundos Int? // duración en segundos
  videoTipoMime         String?
  creadoEn              DateTime          @default(now())

  chats Chat[]
}

model Chat {
  id            String      @id @default(uuid())
  postulacion   Postulacion @relation(fields: [postulacionId], references: [id], onDelete: Cascade)
  postulacionId String
  creadoEn      DateTime    @default(now())

  mensajes Mensaje[]
}

model Mensaje {
  id          String   @id @default(uuid())
  chat        Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId      String
  remitente   Usuario  @relation(fields: [remitenteId], references: [id], onDelete: Cascade)
  remitenteId String
  texto       String?
  urlAdjunto  String? // opcional: url al archivo enviado
  tipoAdjunto String? // mime-type si corresponde
  creadoEn    DateTime @default(now())
}

model DocumentoProveedor {
  id          String          @id @default(uuid())
  proveedor   PerfilProveedor @relation(fields: [proveedorId], references: [id], onDelete: Cascade)
  proveedorId String
  url         String
  tipo        String
  creadoEn    DateTime        @default(now())
}
